# StatMiner Environment Variables
# Copy to .env.local for local dev. NEVER commit actual values.

# ============================================
# LLM Providers (at least one required)
# ============================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENROUTER_API_KEY=
XAI_API_KEY=

# ============================================
# Data Stores
# ============================================
# MongoDB Atlas — sessions, chats, preferences
MONGODB_URI=
MONGODB_DB=statminer

# Neo4j AuraDB — graph data
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ============================================
# App configuration
# ============================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
LOG_LEVEL=info
