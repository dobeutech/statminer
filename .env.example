# StatMiner Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local or any file with real credentials

# ============================================
# REQUIRED
# ============================================

# Neo4j Database Connection
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# NextAuth.js Configuration
# Generate secret with: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:5000
NEXTAUTH_SECRET=

# ============================================
# LLM PROVIDERS — at least one required
# ============================================

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GROK_API_KEY=
REQUESTY_API_KEY=

# ============================================
# GOVERNMENT & ACADEMIC APIs (Optional)
# ============================================

CENSUS_API_KEY=
BLS_API_KEY=
FRED_API_KEY=
CDC_API_KEY=
NOAA_API_KEY=
PUBMED_API_KEY=
ARXIV_API_KEY=
CROSSREF_API_KEY=
SEMANTIC_SCHOLAR_API_KEY=

# ============================================
# FINANCIAL & INTERNATIONAL APIs (Optional)
# ============================================

WORLD_BANK_API_KEY=
IMF_API_KEY=
YAHOO_FINANCE_API_KEY=
UN_DATA_API_KEY=
EUROSTAT_API_KEY=
OECD_API_KEY=

# ============================================
# FIREBASE (Optional)
# ============================================

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# ============================================
# QUEUE & CACHING (Optional)
# ============================================

REDIS_URL=

# ============================================
# SECURITY
# ============================================

WEBHOOK_SECRET=
